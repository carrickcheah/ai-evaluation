# Key for the target bot (referenced as ${BOT_KEY} in a project's eval.config.yaml)
BOT_KEY=eval

# Judge model for the local `claude` CLI (subscription). Default: sonnet
JUDGE_MODEL=sonnet

# Parallel grading workers (keep modest — subscription rate limits)
EVAL_CONCURRENCY=3

# NOTE: do NOT set ANTHROPIC_API_KEY — grading runs on your local `claude`
# subscription. Prereq: `claude` CLI installed and logged into Claude Max.
